# ===========================================
# 智能录单系统 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填写实际值

# -------------------------------------------
# PostgreSQL 数据库配置 (必填)
# 格式: postgresql://用户名:密码@主机:端口/数据库名
# -------------------------------------------
DATABASE_URL=postgresql://smartorder:your_password@localhost:5432/smart_order

# -------------------------------------------
# 豆包 AI 配置 (必填)
# 从 Coze 平台获取 API Key
# -------------------------------------------
COZE_WORKLOAD_IDENTITY_API_KEY=your-coze-api-key-here
COZE_INTEGRATION_BASE_URL=https://api.coze.com
COZE_INTEGRATION_MODEL_BASE_URL=https://model.coze.com

# -------------------------------------------
# 服务器配置 (可选)
# -------------------------------------------
PORT=5000
NODE_ENV=production
CLIENT_DIST_PATH=/www/wwwroot/smart-order-system/client/dist
