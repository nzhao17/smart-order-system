# ===========================================
# 智能录单系统 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填写实际值

# -------------------------------------------
# Supabase 数据库配置 (必填)
# 从 Supabase 项目设置 → API 中获取
# -------------------------------------------
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key-here
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# -------------------------------------------
# 豆包 AI 配置 (必填)
# 从 Coze 平台获取 API Key
# -------------------------------------------
COZE_WORKLOAD_IDENTITY_API_KEY=your-coze-api-key-here
COZE_INTEGRATION_BASE_URL=https://api.coze.com
COZE_INTEGRATION_MODEL_BASE_URL=https://model.coze.com

# -------------------------------------------
# 服务器配置 (可选)
# -------------------------------------------
PORT=5000
NODE_ENV=production
CLIENT_DIST_PATH=/www/wwwroot/smart-order-system/client/dist
